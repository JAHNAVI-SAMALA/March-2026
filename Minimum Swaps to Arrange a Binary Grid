class Solution:
    def minSwaps(self, grid: List[List[int]]) -> int:
        n = len(grid)
        maxRight = []
        
        for row in grid:
            rightmost = -1
            for i in range(n):
                if row[i] == 1:
                    rightmost = i
            maxRight.append(rightmost)
        
        swaps = 0
        
        for i in range(n):
            j = i
            while j < n and maxRight[j] > i:
                j += 1
            
            if j == n:
                return -1
            
            while j > i:
                maxRight[j], maxRight[j - 1] = maxRight[j - 1], maxRight[j]
                swaps += 1
                j -= 1
        
        return swaps
